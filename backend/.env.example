# Required: Groq API key
GROQ_API_KEY=your_groq_api_key_here

# Optional: Redis for session persistence
# If not set, falls back to in-memory storage (sessions reset on restart)
REDIS_URL=redis://localhost:6379

# Required: Supabase/Postgres connection string
DATABASE_URL=postgresql://user:password@host:port/db
# Optional: Override SSL mode for local development
# DATABASE_SSLMODE=require

# Optional: Webhook verification token
WEBHOOK_VERIFY_TOKEN=your_verify_token_here

# CORS Configuration
# Comma-separated list of allowed origins
# For production with Vercel frontend:
CORS_ORIGINS=https://auto-stream-ai-sales-agent.vercel.app
# Or leave empty to use default Vercel regex: https://.*\.vercel\.app
# CORS_ORIGINS=

# Optional: Custom CORS regex (overrides origins list)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Optional: Port for the server (default: 8000)
PORT=8000

# Deprecated alias (supported for compatibility)
# NEXT_PUBLIC_WIDGET_API_URL=https://autostream-ai-sales-agent.onrender.com

# Application Environment
NODE_ENV=production

# Optional: Analytics, monitoring, etc.
# NEXT_PUBLIC_ANALYTICS_ID=
